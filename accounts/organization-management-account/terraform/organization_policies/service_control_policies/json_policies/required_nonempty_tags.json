      "arn:aws:ecs:*:*:service/*",
      "arn:aws:eks:*:*:cluster/*",
      "arn:aws:eks:*:*:nodegroup/*",
      "arn:aws:batch:*:*:compute-environment/*",
      "arn:aws:batch:*:*:job-queue/*",
      "arn:aws:glue:*:*:job/*",
      "arn:aws:glue:*:*:database/*",
      "arn:aws:glue:*:*:table/*",
      "arn:aws:glue:*:*:crawler/*",
      "arn:aws:sns:*:*:*",
      "arn:aws:sqs:*:*:*",
      "arn:aws:kms:*:*:key/*",
      "arn:aws:cloudwatch:*:*:alarm:*",
      "arn:aws:logs:*:*:log-group:*",
      "arn:aws:events:*:*:rule/*",
      "arn:aws:iam::*:role/*",
      "arn:aws:iam::*:user/*",
      "arn:aws:iam::*:policy/*",
