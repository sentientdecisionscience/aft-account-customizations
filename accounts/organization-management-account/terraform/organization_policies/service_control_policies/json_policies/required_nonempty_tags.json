      "arn:aws:sagemaker:*:*:model/*",
      "arn:aws:tag:*:*:resource/*"
    ],
    "Condition": {
      "Null": {
        "aws:RequestTag/Index": true
      }
    }
  },
  {
    "Sid": "DenyDeleteIndexTagAllResources",
    "Effect": "Deny",
    "Action": [
      "tag:UntagResources",
      "ec2:DeleteTags",
      "rds:RemoveTagsFromResource",
      "elasticfilesystem:DeleteTags",
      "elasticache:RemoveTagsFromResource",
      "cloudformation:UntagResource",
      "sns:UntagResource",
      "sqs:UntagQueue",
      "iam:UntagRole",
      "iam:UntagUser",
      "secretsmanager:UntagResource",
      "glue:UntagResource",
      "ecr:UntagResource",
      "states:UntagResource",
      "cloudwatch:UntagResource",
      "lambda:UntagResource",
      "dynamodb:UntagResource",
      "kms:UntagResource",
      "batch:UntagResource",
      "tag:UntagResources"
    ],
    "Resource": [
      "*"
    ],
    "Condition": {
      "ForAnyValue:StringEquals": {
        "aws:TagKeys": [
          "Index"
        ]
      }
    }
  }
]